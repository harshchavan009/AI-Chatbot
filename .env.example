# --- Required External APIs ---
# OpenAI API Key (Optional if using Gemini)
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot Token (Optional if only using Web UI)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API (Recommended)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Database Settings ---
# For Local: mongodb://localhost:27017
# For Live: mongodb+srv://<user>:<password>@cluster.mongodb.net/chatbot_db
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=chatbot_db
MAX_CONTEXT_MESSAGES=10

# --- App Settings ---
APP_NAME="Nova AI"
MOCK_MODE=false
PRODUCTION=false
PORT=8000

# IMPORTANT: Set a strong random string for production
SECRET_KEY=your-super-secret-key-here
